# Node Environment
NODE_ENV=development

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://mongo:27017/clipper_db

# Redis
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-token-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.3
OPENAI_TIMEOUT_MS=180000
OPENAI_MAX_RETRIES=4
OPENAI_RETRY_DELAY_MS=1500

# File Storage
UPLOAD_DIR=./uploads
STORAGE_TYPE=local
YTDLP_MAX_RETRIES=3
YTDLP_RETRY_DELAY_MS=3000
YTDLP_TIMEOUT_MS=300000
# Optional: path to Netscape cookies file mounted inside worker container
YTDLP_COOKIES_PATH=/app/storage/youtube-cookies.txt
# Optional: proxy URL for yt-dlp (example: http://user:pass@host:port)
YTDLP_PROXY_URL=
# For S3/R2/MinIO (future)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Webhook (optional)
WEBHOOK_URL=

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Billing (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitoring (future)
SENTRY_DSN=
